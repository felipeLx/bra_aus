# ──────────────────────────────────────────────────────────────
# Database (Supabase PostgreSQL)
#
# DATABASE_URL — runtime connection (can be pooler URL, port 6543)
#   Supabase Dashboard → Settings → Database → Connection pooling → Transaction mode
#   Use pooler if you get IPv6 connection errors from WSL
#
# DIRECT_URL — used only by `bun run db:migrate` (must be direct, port 5432)
#   Supabase Dashboard → Settings → Database → Connection string → URI
#
# Note: URL-encode special chars in the password  @ → %40  / → %2F  % → %25  : → %3A
# ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ──────────────────────────────────────────────────────────────
# Session
# Generate with: openssl rand -base64 32
# ──────────────────────────────────────────────────────────────
SESSION_SECRET="change-me-with-a-strong-random-secret"

# ──────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────
APP_URL="http://localhost:5173"

# ──────────────────────────────────────────────────────────────
# Admin account (used by prisma/seed.ts — bun run db:seed)
# ──────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@yourdomain.com"
SEED_ADMIN_PASSWORD="change-me-after-first-login"

# ──────────────────────────────────────────────────────────────
# Email — Resend  (https://resend.com)
# Free tier: 3,000 emails/month · 100/day · no credit card
# 1. Sign up at resend.com → create API key
# 2. In sandbox mode all emails go to your verified address only
# 3. Add & verify your domain to send to anyone in production
# ──────────────────────────────────────────────────────────────
RESEND_API_KEY="mlsn.8698724f1f0969a03c1214f2c8ba19a312cb58d4ab6c599b0ea51d208ee6ef9e"
EMAIL_FROM="Rio-Aus Flights <onboarding@resend.dev>"
